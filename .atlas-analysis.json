  "keyFeatures": [
    "Interactive Pi visualization with color-coded digit grid and sphere view",
    "Pi memory game with Normal, Time Attack, and Sudden Death modes",
    "Animated historical timeline from 2000 BC to modern supercomputers",
    "PiBot chatbot with preset questions and hardcoded educational responses",
    "Konami-style Easter egg triggered by typing '3.14159'",
    "Express 5 REST API server with OpenAPI spec and Orval code generation",
    "PostgreSQL database with Drizzle ORM and Zod validation",
    "pnpm monorepo with TypeScript composite project references"
  ],
  "publicApiSurface": [
    "GET /api/healthz — Health check endpoint returning HealthStatus",
    "HealthCheckResponse (Zod schema from @workspace/api-zod)",
    "useHealthCheck (React Query hook from @workspace/api-client-react)",
    "healthCheck (fetch function from @workspace/api-client-react)",
    "Hero component (artifacts/pi-day/src/components/sections/Hero.tsx)",
